#!/usr/bin/env bash
set -euo pipefail

# Resolve symlink chain so AUTOPILOT_ROOT points at the real repo, not ~/.local/bin.
__src="${BASH_SOURCE[0]}"
while [ -L "$__src" ]; do
  __dir="$(cd -P "$(dirname "$__src")" && pwd)"
  __src="$(readlink "$__src")"
  [[ "$__src" != /* ]] && __src="$__dir/$__src"
done
AUTOPILOT_ROOT="$(cd -P "$(dirname "$__src")/.." && pwd)"
unset __src __dir
export AUTOPILOT_ROOT

# shellcheck source=../lib/ui.sh
source "$AUTOPILOT_ROOT/lib/ui.sh"
# shellcheck source=../lib/config.sh
source "$AUTOPILOT_ROOT/lib/config.sh"
# shellcheck source=../lib/phases.sh
source "$AUTOPILOT_ROOT/lib/phases.sh"
# shellcheck source=../lib/state.sh
source "$AUTOPILOT_ROOT/lib/state.sh"
# shellcheck source=../lib/linear.sh
source "$AUTOPILOT_ROOT/lib/linear.sh"
# shellcheck source=../lib/plan.sh
source "$AUTOPILOT_ROOT/lib/plan.sh"
# shellcheck source=../lib/agent.sh
source "$AUTOPILOT_ROOT/lib/agent.sh"
# shellcheck source=../lib/checkpoint.sh
source "$AUTOPILOT_ROOT/lib/checkpoint.sh"
# shellcheck source=../lib/review.sh
source "$AUTOPILOT_ROOT/lib/review.sh"
# shellcheck source=../lib/phase01.sh
source "$AUTOPILOT_ROOT/lib/phase01.sh"
# shellcheck source=../lib/phase06.sh
source "$AUTOPILOT_ROOT/lib/phase06.sh"

usage() {
  cat <<EOF
Usage: autopilot [--interactive | --full] <linear-url-or-id | plan-file.md>

Runs the ralph-loop from worktree creation through merge. Resumable: re-run to
continue from the last completed phase.

Two input forms:
  <linear-url-or-id>   Full pipeline: fetch ticket, research, plan, implement,
                       review, merge.
  <plan-file.md>       Plan-file mode: skip the Linear fetch, research, and plan
                       phases. Creates a worktree, seeds it with the supplied
                       plan, and resumes at the implement phase. Detected when the
                       argument ends in .md or names an existing file.

Modes:
  --interactive (default)   Pause at plan TLDR and post-review checkpoints.
                            (Plan-file mode skips the plan checkpoint — the plan
                            is already yours — but keeps the post-review one.)
  --full                    No checkpoints. Auto-approves plan; takes
                            AUTOPILOT_DEFAULT_ACTION (default 'pr') after review.

Env vars (see .autopilotrc.example):
  AUTOPILOT_MODE            interactive | full (overridden by CLI flag)
  AUTOPILOT_DEFAULT_ACTION  merge | pr | preview | hold (full mode only; default pr)
  AUTOPILOT_WORKTREE_BASE   Default: \$HOME/wt
  AUTOPILOT_AGENT_CMD       Default: claude -p ...
  AUTOPILOT_MODEL           Default: claude-opus-4-8
  AUTOPILOT_VERIFY_CMD      Default: make check test
  AUTOPILOT_SETUP_CMD       Default: (none)
  AUTOPILOT_SYMLINKS        Newline-separated paths to symlink from source repo

Prerequisite: the agent referenced by AUTOPILOT_AGENT_CMD must have a Linear
MCP server installed and authenticated.
EOF
}

MODE_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --full)        MODE_OVERRIDE="full"; shift ;;
    --interactive) MODE_OVERRIDE="interactive"; shift ;;
    -h|--help)     usage; exit 0 ;;
    --) shift; break ;;
    -*) log_err "Unknown flag: $1"; usage; exit 2 ;;
    *)  break ;;
  esac
done

[[ $# -lt 1 ]] && { usage; exit 2; }
INPUT="$1"
[[ -n "$MODE_OVERRIDE" ]] && AUTOPILOT_MODE="$MODE_OVERRIDE"
: "${AUTOPILOT_MODE:=interactive}"
: "${AUTOPILOT_DEFAULT_ACTION:=pr}"
export AUTOPILOT_MODE AUTOPILOT_DEFAULT_ACTION
log_info "Mode: $AUTOPILOT_MODE"

# Resolve the repo root from wherever we're invoked. `git rev-parse` handles
# subdirectories and linked worktrees (where .git is a file, not a directory) —
# an `-d .git` test would reject both. CWD is kept separately so a relative plan
# path resolves against the caller's directory, not the repo root.
CWD="$(pwd)"
SOURCE_REPO="$(git -C "$CWD" rev-parse --show-toplevel 2>/dev/null || true)"
[[ -n "$SOURCE_REPO" ]] || { log_err "Run from inside a git repo (cwd: $CWD)"; exit 1; }

config_load

# Two input forms: a Linear URL/ID (full pipeline) or a plan file (skip the
# Linear fetch, research, and plan phases). See is_plan_input in lib/plan.sh.
PLAN_MODE=0
if is_plan_input "$INPUT"; then
  PLAN_MODE=1
  PLAN_SRC="$INPUT"
  [[ "$PLAN_SRC" = /* ]] || PLAN_SRC="$CWD/$PLAN_SRC"
  [[ -f "$PLAN_SRC" ]] || { log_err "Plan file not found: $PLAN_SRC"; exit 1; }
  SLUG=$(plan_slug "$PLAN_SRC")
  TICKET="$SLUG"
  TICKET_LC="$SLUG"
  PROJECT=$(config_project_name)
  WT="${AUTOPILOT_WORKTREE_BASE}/${PROJECT}/${SLUG}"
  export PLAN_SRC
  log_info "Plan-file mode: $PLAN_SRC"
else
  TICKET=$(linear_parse_ticket "$INPUT") || { log_err "Bad Linear input"; exit 1; }
  SLUG=$(linear_parse_slug "$INPUT")
  PROJECT=$(config_project_name)
  TICKET_LC=$(echo "$TICKET" | tr '[:upper:]' '[:lower:]')
  WT="${AUTOPILOT_WORKTREE_BASE}/${PROJECT}/${TICKET_LC}"
fi
export TICKET SLUG PROJECT WT TICKET_LC

# Marker file so a shell wrapper can `cd` after we exit. See README "Auto-cd".
state_write_last_wt "$WT"

set_term_title "$TICKET"
trap 'set_term_title "$TICKET · done"' EXIT
# A Ctrl-C (or kill) must abort the run WITHOUT advancing state. Without this,
# the agent CLI catches SIGINT and exits 0, which would otherwise look like a
# successful phase and get marked done — silently skipping real work on resume.
trap 'log_err "Interrupted — stopping. State not advanced; re-run to resume this phase."; exit 130' INT TERM

DATE=$(date -u +%F)
export DATE

if [[ "$PLAN_MODE" -eq 1 ]]; then
  # Plan-file mode: create+seed the worktree, then jump straight to implement.
  # The supplied plan is pre-approved, so there is no plan checkpoint.
  if need plan_approved; then
    plan_setup_worktree "$PLAN_SRC" "$SOURCE_REPO"
    mark_phase plan_approved
  fi
else
  if need worktree_done; then
    phase01_worktree "$INPUT" "$SOURCE_REPO"
    mark_phase worktree_done
  fi

  if need research_done; then
    run_phase 02-research || { log_err "research phase failed — stopping."; exit 1; }
    mark_phase research_done
  fi

  if need plan_done; then
    run_phase 03-plan || { log_err "plan phase failed — stopping."; exit 1; }
    mark_phase plan_done
  fi

  if need plan_approved; then
    PLAN_PATH=$(jq -r .plan_path "$WT/.autopilot/state.json")
    export PLAN_PATH
    checkpoint_plan "$WT/$PLAN_PATH"
    mark_phase plan_approved
  fi
fi

if need implement_done; then
  PLAN_PATH=$(jq -r .plan_path "$WT/.autopilot/state.json")
  export PLAN_PATH
  export VERIFY_CMD="$AUTOPILOT_VERIFY_CMD"
  run_phase 04-implement || { log_err "implement phase failed — stopping."; exit 1; }
  # Guard: implement must produce real work. If it exits 0 but leaves zero commits
  # over the base (e.g. the agent was interrupted and the CLI exited cleanly), do
  # NOT mark it done — otherwise resume skips ahead and review runs an empty diff.
  impl_base=$(base_ref "$WT")
  impl_commits=$(git -C "$WT" rev-list --count "${impl_base}..HEAD" 2>/dev/null || echo 0)
  if [[ "$impl_commits" -lt 1 ]]; then
    log_err "implement finished with 0 commits over ${impl_base} — likely interrupted or incomplete. Not advancing; re-run to retry."
    exit 1
  fi
  mark_phase implement_done
fi

# Up to 3 review cycles, but stop early once a cycle converges (its finder pass —
# reviewer + adversary + codex — leaves nothing open, so the fixer is skipped).
for n in 1 2 3; do
  marker="review_cycle_${n}_done"
  if need "$marker"; then
    rc=0
    run_review_cycle "$n" || rc=$?
    if [[ "$rc" -eq "$REVIEW_CONVERGED" ]]; then
      log_ok "Review converged at cycle $n — skipping remaining cycles."
      mark_phase review_cycle_3_done   # advance past all cycle markers; resume-safe
      break
    elif [[ "$rc" -ne 0 ]]; then
      log_err "review cycle $n failed — stopping."
      exit 1
    fi
    mark_phase "$marker"
  fi
done

# Visual verification (UI tasks): after code review converges, before the human
# checkpoint. The prompt self-gates (skips non-UI work in `auto`); unmet criteria
# become open items the fixer addresses, then we re-verify (bounded). A phase error
# is advisory — it warns and continues to the checkpoint rather than aborting a
# successful implement+review.
if need visual_verify_done; then
  if visual_enabled; then
    VISUAL_MODE="$AUTOPILOT_VISUAL"
    APP_CMD="$AUTOPILOT_APP_CMD"
    BASE_SHA=$(git -C "$WT" merge-base "$(base_ref "$WT")" HEAD)
    HEAD_SHA=$(git -C "$WT" rev-parse HEAD)
    export VISUAL_MODE APP_CMD BASE_SHA HEAD_SHA
    for v in 1 2; do
      log_info "Visual verification pass ${v}/2"
      run_phase 07-visual-verify review || { log_warn "visual-verify phase errored; continuing."; break; }
      [[ "$(feedback_open_count "$WT/.autopilot/feedback.json")" -eq 0 ]] && break
      run_phase 05c-fixer review || { log_err "visual fix phase failed — stopping."; exit 1; }
    done
  else
    log_info "Visual verification disabled (AUTOPILOT_VISUAL=off)."
  fi
  mark_phase visual_verify_done
fi

if need review_approved; then
  branch=$(jq -r .branch "$WT/.autopilot/state.json")
  commits=$(git -C "$WT" rev-list --count "$(base_ref "$WT")..HEAD")
  checkpoint_review "$branch" "$commits"
  mark_phase review_approved
fi

if need merged; then
  PLAN_PATH=$(jq -r .plan_path "$WT/.autopilot/state.json")
  export PLAN_PATH
  phase06_merge_or_pr || { log_err "merge/pr phase failed — stopping."; exit 1; }
  mark_phase merged
fi

TOTAL_COST=$(state_total_cost)
FINAL_BRANCH=$(jq -r '.branch // "?"' "$WT/.autopilot/state.json" 2>/dev/null || echo "?")
log_ok "Autopilot done for $TICKET (phase: $(state_phase))."
echo "  Worktree: $WT"
echo "  Branch:   $FINAL_BRANCH"
echo "  Cost:     \$$(printf '%.4f' "$TOTAL_COST")"
