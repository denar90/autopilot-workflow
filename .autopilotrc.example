# autopilot per-project config. Copy this file to .autopilotrc in any repo you
# want autopilot to drive. Values use `: "${X:=default}"` so caller env wins.

# Where worktrees live. Each worktree is "${AUTOPILOT_WORKTREE_BASE}/${project}/${ticket}".
: "${AUTOPILOT_WORKTREE_BASE:=$HOME/wt}"

# Linear personal API key (lin_api_...). Strongly recommended: with it set, the
# ticket fetch uses the Linear REST API directly — workspace-portable and headless,
# so `--full` runs work without an interactively-authenticated Linear MCP. Without
# it, autopilot falls back to the agent's Linear MCP, which needs OAuth and will
# fail in headless/--full mode. Get one at Linear → Settings → Security & access.
# LINEAR_API_KEY="lin_api_xxxxxxxx"

# Default model for implement/plan/research. claude-opus-4-8 is the top Opus-tier
# model ($5/$25 per MTok) — strong agentic coding at a much lower cost than the
# frontier claude-fable-5 ($10/$50). Set claude-fable-5 (or claude-mythos-5 with
# Project Glasswing access) if you want maximum capability and accept the cost.
: "${AUTOPILOT_MODEL:=claude-opus-4-8}"

# Coding agent invocation. Stdin = prompt, stdout = stream.
: "${AUTOPILOT_AGENT_CMD:=claude -p --output-format=stream-json --verbose --permission-mode bypassPermissions --model $AUTOPILOT_MODEL}"

# Cheaper model for the review cycle (reviewer/adversary/fixer). The 05x loop runs
# up to 3× per task and is the biggest cost driver; critiquing/patching an existing
# diff doesn't need the frontier model. claude-opus-4-8 is ~half the cost of fable-5;
# claude-sonnet-4-6 or claude-haiku-4-5 are cheaper still.
: "${AUTOPILOT_MODEL_REVIEW:=claude-opus-4-8}"
: "${AUTOPILOT_AGENT_CMD_REVIEW:=claude -p --output-format=stream-json --verbose --permission-mode bypassPermissions --model $AUTOPILOT_MODEL_REVIEW}"

# Cross-review agent (a second model that reviews after Claude's reviewer/adversary,
# before the fixer). Runs every review cycle. Stdin = prompt. Leave empty to disable
# even when codex is installed. Skipped automatically if the binary isn't on PATH.
# `--json` makes codex emit JSONL events, which autopilot renders via codex_pretty;
# drop it to fall back to codex's raw plain-text stream.
: "${AUTOPILOT_CODEX_CMD:=codex exec --json --full-auto}"

# Files to symlink from the source repo into the worktree on creation.
# Newline-separated list of paths relative to the source repo root.
AUTOPILOT_SYMLINKS=".env
.mcp.json"

# Post-checkout setup command. Runs inside the fresh worktree.
AUTOPILOT_SETUP_CMD="pnpm install && pnpm prisma generate"

# Verification command run at end of implement and after each fixer cycle.
AUTOPILOT_VERIFY_CMD="make check test"

# Run mode: 'interactive' (default) or 'full'. CLI --full / --interactive overrides this.
: "${AUTOPILOT_MODE:=interactive}"

# In 'full' mode, what to do after review completes.
# One of: merge / pr / preview / hold.
: "${AUTOPILOT_DEFAULT_ACTION:=pr}"

# Max review cycles (clamped 1-3). Default 1 = one round (reviewer + adversary +
# codex -> fixer, with no re-review of the fixer's output; the fixer still makes
# AUTOPILOT_VERIFY_CMD pass). Set 2-3 to re-review fixes on riskier changes.
: "${AUTOPILOT_REVIEW_CYCLES:=1}"

# Per-commit review: 'on' reviews each new commit individually (on the review model)
# after implement, before the review cycle -- catches per-commit issues earlier.
# N extra calls (capped at 20), so default off. Findings feed the same fixer.
: "${AUTOPILOT_COMMIT_REVIEW:=off}"

# Per-run metrics: one JSON line per run (cost, cycles, findings by source/status,
# per-phase cost). 'off' disables. Analyze with jq; great for evidence-based tuning.
: "${AUTOPILOT_METRICS:=on}"
: "${AUTOPILOT_METRICS_FILE:=${XDG_STATE_HOME:-$HOME/.local/state}/autopilot/runs.jsonl}"
# Optional exporter: a command the record is piped to (PostHog/Langfuse/webhook).
# e.g. AUTOPILOT_METRICS_SINK="curl -sS -X POST -d @- https://your-endpoint"
AUTOPILOT_METRICS_SINK=""

# Visual verification of UI tasks (runs after review converges, before merge).
# auto = run, but the agent skips changes with no user-facing UI; on = always
# verify; off = never run the phase.
: "${AUTOPILOT_VISUAL:=auto}"

# How the visual-verify phase launches the app. Leave empty to let the agent use
# the project's run skill / dev script; or set an explicit command.
AUTOPILOT_APP_CMD=""
